# Secrets
AZURE_CREDENTIALS=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_TO=

# Variables
AZURE_RESOURCE_GROUP=
AZURE_VM=
MAIL_SUBJECT="Reminder: your virtual machine will shut down soon"
MAIL_BODY="The virtual machine will automatically shut down soon. If necessary, you can cancel the operation [by clicking here](). To reactivate the virtual machine, visit the [Azure portal](https://portal.azure.com).<br><br>Reply to this email for support."
NOTIFY_STOP=true
RUN_STOP=true
